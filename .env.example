# Obrigatorio
META_ACCESS_TOKEN=seu_access_token_aqui

# Opcional - conta padrao usada quando uma chamada nao passa account_id
META_AD_ACCOUNT_ID=

# Opcional - restringe quais contas o MCP pode acessar (ids separados por virgula)
# Ex.: META_ACCOUNT_ALLOWLIST=364442698159815,1153243643313739
META_ACCOUNT_ALLOWLIST=

# Opcional - geracao de PDF local
# Caminho do Chrome/Edge. No Vercel, sera necessario configurar um Chromium
# compativel antes de usar a ferramenta de PDF em producao.
META_BROWSER_PATH=
# Pasta onde salvar os PDFs (padrao: Documents/Relatorios-Meta)
META_REPORT_OUTPUT_DIR=
# Template HTML customizado. Se vazio, usa o template interno do projeto.
META_REPORT_TEMPLATE=
# Logo customizada para o template interno. Se vazio, usa assets/logo-lima-soares-vermelho.png.
META_REPORT_LOGO=

# Opcional - seguranca do endpoint HTTP (Vercel)
# Deixe vazio para usar o conector personalizado do Claude sem OAuth.
MCP_SECRET=
