# Obrigatório
META_ACCESS_TOKEN=seu_access_token_aqui

# Opcional — conta padrão usada quando uma chamada não passa account_id
META_AD_ACCOUNT_ID=

# Opcional — restringe quais contas o MCP pode acessar (ids separados por vírgula)
# Ex.: META_ACCOUNT_ALLOWLIST=364442698159815,1153243643313739
META_ACCOUNT_ALLOWLIST=

# Opcional — geração de PDF
# Caminho do Chrome/Edge (detecta automático se vazio)
META_BROWSER_PATH=
# Pasta onde salvar os PDFs (padrão: Documentos/Relatorios-Meta)
META_REPORT_OUTPUT_DIR=
# Template HTML customizado (padrão: templates/relatorio.html)
META_REPORT_TEMPLATE=

# Opcional — segurança do endpoint HTTP (Vercel)
MCP_SECRET=
