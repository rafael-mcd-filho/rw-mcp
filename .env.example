# Obrigatorio
META_ACCESS_TOKEN=seu_access_token_aqui

# Opcional - conta padrao usada quando uma chamada nao passa account_id
META_AD_ACCOUNT_ID=

# Opcional - restringe quais contas o MCP pode acessar (ids separados por virgula)
# Ex.: META_ACCOUNT_ALLOWLIST=364442698159815,1153243643313739
META_ACCOUNT_ALLOWLIST=

# Opcional - geracao de PDF local
# Caminho do Chrome/Edge. No Vercel, sera necessario configurar um Chromium
# compativel antes de usar a ferramenta de PDF em producao.
META_BROWSER_PATH=
# Pasta onde salvar os PDFs (padrao: Documents/Relatorios-Meta)
META_REPORT_OUTPUT_DIR=
# Template HTML customizado. Se vazio, usa o template interno do projeto.
META_REPORT_TEMPLATE=
# Logo customizada para o template interno. Se vazio, usa assets/logo-lima-soares-vermelho.png.
META_REPORT_LOGO=

# Opcional - seguranca do endpoint HTTP (Vercel)
# Deixe vazio para usar o conector personalizado do Claude sem OAuth.
MCP_SECRET=

# Google Ads - necessario para tools Google e relatorio integrado
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
# MCC/login customer id, somente numeros ou com tracos
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Opcional para scripts locais
GOOGLE_ADS_CUSTOMER_ID=

# Base de clientes - webhook da Plugue/n8n
# Retorno esperado: [{ nome_cliente, id_conta_meta_ads, id_conta_google, id_grupo_cliente }]
CLIENTS_WEBHOOK_URL=
CLIENTS_WEBHOOK_TOKEN=

# PDF em Vercel / serverless
BROWSERLESS_TOKEN=
BROWSERLESS_WS_ENDPOINT=
BLOB_READ_WRITE_TOKEN=
PUBLIC_BASE_URL=

# Opcional - expoe as tools qa_* de QA visual (1/true). Padrao: ocultas.
EXPOSE_QA_TOOLS=

# MinIO - bucket com os criativos (list_minio_files + minio_key em meta_create_image/meta_create_video)
# ATENCAO: MINIO_ENDPOINT e o endpoint da API S3, NAO a URL do console web.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=metaads
