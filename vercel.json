{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    },
    "api/mcp.ts": {
      "maxDuration": 60,
      "includeFiles": [
        "src/**",
        "assets/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ]
}
