{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    },
    "api/mcp.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ]
}
